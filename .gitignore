# ===== PQC Messenger .gitignore =====

# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
*.egg
.pytest_cache/

# Environment
.env
.env.local
.env.production

# Database
*.db
*.sqlite3

# Encrypted uploads (never commit encrypted files)
backend/uploads/*
!backend/uploads/.gitkeep

# Node
node_modules/
frontend/node_modules/

# Build output
frontend/dist/
frontend/build/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# liboqs build artifacts (if built locally)
liboqs/
liboqs-build/

# GCP secrets (NEVER commit)
**/service-account.json
**/credentials.json

# npm cache
npm-cache/

