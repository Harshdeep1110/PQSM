# PQC Messenger — Environment Variables
# Copy this file to .env and fill in your values.
# Do NOT commit .env to version control.

# --- Backend ---
# SQLite database path (use /data/pqc_messenger.db for Render persistent disk)
DATABASE_URL=sqlite:///pqc_messenger.db

# Directory for encrypted file uploads (use /data/uploads on Render)
UPLOAD_DIR=backend/uploads

# Comma-separated list of allowed CORS origins (your Vercel URL in production)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Random secret key for signing sessions (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-to-a-random-string

# Maximum file upload size in MB
MAX_FILE_SIZE_MB=50

# Frontend URL (set to your Vercel deployment URL in production)
FRONTEND_URL=http://localhost:5173
