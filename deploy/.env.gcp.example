# =============================================================================
# PQC Messenger — Google Cloud Platform Environment Variables
# Copy this to .env and fill in your values.
# Created by: TASK-31 (Phase 7)
# =============================================================================

# --- GCP Project ---
GCP_PROJECT_ID=pqsm-18197

# --- Feature Flags (toggle GCP integrations on/off) ---
USE_FIREBASE_AUTH=true
STORAGE_BACKEND=firestore
# Options: firestore | sqlite
ENABLE_KMS=false
# Set to true once KMS key ring is created
ENABLE_AUDIT_LOGGING=true

# --- Firebase ---
FIREBASE_PROJECT_ID=pqsm-18197
# Path to the Firebase/GCP service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/service-account.json

# --- Google Cloud Storage ---
GCS_BUCKET_NAME=pqsm-18197-encrypted-data

# --- Google Cloud KMS (stub for now) ---
KMS_LOCATION=global
KMS_KEY_RING=pqc-messenger
KMS_KEY_NAME=master-envelope-key

# --- CORS ---
ALLOWED_ORIGINS=https://your-frontend-domain.web.app,http://localhost:5173

# --- Server ---
PORT=8080
MAX_FILE_SIZE_MB=50

# --- Frontend (set these in Vercel/Firebase Hosting env vars) ---
# VITE_BACKEND_URL=https://your-cloud-run-service-url
# VITE_BACKEND_WS_URL=wss://your-cloud-run-service-url
# VITE_FIREBASE_API_KEY=your-api-key
# VITE_FIREBASE_AUTH_DOMAIN=pqsm-18197.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=pqsm-18197
# VITE_FIREBASE_STORAGE_BUCKET=pqsm-18197.appspot.com
# VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
# VITE_FIREBASE_APP_ID=your-app-id
